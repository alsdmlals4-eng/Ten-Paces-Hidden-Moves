{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/alsdmlals4-eng/Ten-Paces-Hidden-Moves/schemas/design-document-registry-v3.schema.json",
  "title": "Ten Paces Design Document Registry v3",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_role", "project_name", "source_of_truth_policy", "publication_note", "required_responsibility_coverage", "available_responsibility_catalog", "documents"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": 3},
    "registry_role": {"const": "ai-design-document-router-and-publication-index"},
    "project_name": {"type": "string", "minLength": 1},
    "source_of_truth_policy": {"type": "string", "minLength": 1},
    "publication_note": {"type": "string", "minLength": 1},
    "required_responsibility_coverage": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "available_responsibility_catalog": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "documents": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/document"}}
  },
  "$defs": {
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "document_id", "title", "discipline", "responsibility_coverage", "status",
        "source_path", "source_format", "source_role", "publication_policy",
        "output_pdf", "output_docx", "asset_dir", "diagram_policy",
        "publication_manifest", "generator", "required_sections"
      ],
      "properties": {
        "document_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "title": {"type": "string", "minLength": 1},
        "discipline": {"type": "string", "minLength": 1},
        "responsibility_coverage": {"type": "array", "minItems": 1, "items": {"type": "string"}, "uniqueItems": true},
        "status": {"enum": ["ACTIVE", "SUPPORT", "HOLD", "BACKUP", "REMOVAL_CANDIDATE", "NOT_INSTALLED"]},
        "source_path": {"type": "string", "minLength": 1},
        "source_format": {"enum": ["markdown", "json"]},
        "source_role": {"enum": ["narrative_spec", "structured_data", "registry", "state"]},
        "publication_policy": {"enum": ["source_only", "milestone_sync", "always_sync"]},
        "output_pdf": {"type": ["string", "null"]},
        "output_docx": {"type": ["string", "null"]},
        "asset_dir": {"type": ["string", "null"]},
        "diagram_policy": {"enum": ["none", "mermaid", "generated"]},
        "publication_manifest": {"type": ["string", "null"]},
        "generator": {"type": ["string", "null"]},
        "required_sections": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      },
      "allOf": [
        {
          "if": {"properties": {"publication_policy": {"const": "source_only"}}, "required": ["publication_policy"]},
          "then": {
            "properties": {
              "output_pdf": {"type": "null"},
              "output_docx": {"type": "null"},
              "asset_dir": {"type": "null"},
              "diagram_policy": {"const": "none"},
              "publication_manifest": {"type": "null"},
              "generator": {"type": "null"}
            }
          }
        },
        {
          "if": {"properties": {"publication_policy": {"enum": ["milestone_sync", "always_sync"]}}, "required": ["publication_policy"]},
          "then": {
            "properties": {
              "output_pdf": {"type": "string", "minLength": 1},
              "publication_manifest": {"type": "string", "minLength": 1},
              "generator": {"type": "string", "minLength": 1}
            }
          }
        }
      ]
    }
  }
}
